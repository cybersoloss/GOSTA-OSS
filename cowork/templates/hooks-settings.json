{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash cowork/hooks/log-dispatch.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          },
          {
            "type": "command",
            "command": "bash cowork/hooks/check-signal-first.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash cowork/hooks/log-dispatch.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash cowork/hooks/check-cap-overage.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          },
          {
            "type": "command",
            "command": "bash cowork/hooks/check-afc-section.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash cowork/hooks/log-dispatch.sh",
            "timeout": 5000,
            "async": true,
            "asyncRewake": false
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash cowork/hooks/audit-closeout.sh",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
